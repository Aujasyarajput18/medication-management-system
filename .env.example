# ══════════════════════════════════════════════════════════════════════════════
# AUJASYA — Backend Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env files — only .env.example is tracked
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aujasya:password@localhost:5432/aujasya_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_DB=1
REDIS_RATE_LIMIT_DB=2

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_in_production_64_char_random_hex_string_here_abcdef12
ENCRYPTION_MASTER_KEY=change_me_in_production_64_char_random_hex_aes_master_key_here
ENCRYPTION_KEY_VERSION=v1

# ── Authentication ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMS (Msg91) ───────────────────────────────────────────────────────────────
MSG91_API_KEY=
MSG91_SENDER_ID=AUJASY
MSG91_TEMPLATE_ID_OTP=
MSG91_TEMPLATE_ID_REMINDER=

# ── WhatsApp (Wati) ───────────────────────────────────────────────────────────
WATI_API_URL=https://live-mt-server.wati.io
WATI_API_TOKEN=
WATI_TEMPLATE_CAREGIVER_ALERT=
WATI_TEMPLATE_REFILL_REMINDER=
WATI_TEMPLATE_CAREGIVER_INVITE=

# ── Firebase (FCM) ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_WEB_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Aujasya
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4
