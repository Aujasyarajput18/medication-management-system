# ══════════════════════════════════════════════════════════════════════════════
# AUJASYA — Backend Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env files — only .env.example is tracked
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aujasya:password@localhost:5432/aujasya_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_DB=1
REDIS_RATE_LIMIT_DB=2

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_in_production_64_char_random_hex_string_here_abcdef12
ENCRYPTION_MASTER_KEY=change_me_in_production_64_char_random_hex_aes_master_key_here
ENCRYPTION_KEY_VERSION=v1

# ── Authentication ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMS (Msg91) ───────────────────────────────────────────────────────────────
MSG91_API_KEY=
MSG91_SENDER_ID=AUJASY
MSG91_TEMPLATE_ID_OTP=
MSG91_TEMPLATE_ID_REMINDER=

# ── WhatsApp (Wati) ───────────────────────────────────────────────────────────
WATI_API_URL=https://live-mt-server.wati.io
WATI_API_TOKEN=
WATI_TEMPLATE_CAREGIVER_ALERT=
WATI_TEMPLATE_REFILL_REMINDER=
WATI_TEMPLATE_CAREGIVER_INVITE=

# ── Firebase (FCM) ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_WEB_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Aujasya
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 2 — AI Intelligence & Clinical Decision Layer
# ══════════════════════════════════════════════════════════════════════════════

# ── Bhashini (Voice) ──────────────────────────────────────────────────────────
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_API_URL=https://dhruva-api.bhashini.gov.in
BHASHINI_STT_SERVICE_ID=
BHASHINI_TTS_SERVICE_ID=
BHASHINI_NMT_SERVICE_ID=

# ── Ekacare (Medicine Database) ───────────────────────────────────────────────
EKACARE_API_URL=https://api.ekacare.com
EKACARE_API_KEY=
EKACARE_RATE_LIMIT_PER_MINUTE=60

# ── PMBJP (Jan Aushadhi) ──────────────────────────────────────────────────────
PMBJP_API_URL=https://janaushadhi.gov.in/api
PMBJP_API_KEY=
PMBJP_LOCATOR_RADIUS_KM=25

# ── Prayer Times APIs ─────────────────────────────────────────────────────────
ALADHAN_API_URL=https://api.aladhan.com/v1
SUNRISE_SUNSET_API_URL=https://api.sunrise-sunset.org

# ── Drug Interaction APIs ─────────────────────────────────────────────────────
RXNORM_API_URL=https://rxnav.nlm.nih.gov/REST
OPENFDA_API_URL=https://api.fda.gov/drug
OPENFDA_API_KEY=

# ── Exotel (IVR) ──────────────────────────────────────────────────────────────
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=

# ── AI Models ─────────────────────────────────────────────────────────────────
PILL_MODEL_VERSION=v1
PILL_MODEL_CONFIDENCE_THRESHOLD=0.70
PILL_MODEL_MOCK=true

# ── LLaVA Microservice ────────────────────────────────────────────────────────
LLAVA_SERVICE_URL=http://llava-service:8001
LLAVA_CONFIDENCE_THRESHOLD=0.65
LLAVA_MAX_IMAGE_SIZE_MB=10
LLAVA_MOCK=true

# ── Mapbox (for Jan Aushadhi map) ─────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Redis (Phase 2 cache additions) ───────────────────────────────────────────
REDIS_TTS_CACHE_DB=5
REDIS_PRAYER_CACHE_DB=6
