{
  "name": "aujasya",
  "version": "1.0.0",
  "private": true,
  "description": "Aujasya — Medication Adherence PWA for Indian Adults",
  "author": "Team 70 (Aujasya Rajput, Adarsh Mishra, Aryan Damara, Darsh Bansal, Abhinav Sharma)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @aujasya/web dev",
    "build": "pnpm --filter @aujasya/web build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "test:web": "pnpm --filter @aujasya/web test",
    "test:e2e": "pnpm --filter @aujasya/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "husky": "^9.1.4",
    "prettier": "^3.3.3",
    "lint-staged": "^15.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
